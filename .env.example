# Copia questo file in .env.local e inserisci i valori del TUO progetto Firebase.
# Li trovi in: Firebase Console > Impostazioni progetto > "Le tue app" (config web).
# Il prefisso VITE_ è obbligatorio perché Vite esponga la variabile al client.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
# IMPORTANTE per il Realtime Database (es. https://NOME-default-rtdb.europe-west1.firebasedatabase.app)
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
